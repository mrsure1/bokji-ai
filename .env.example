# =============================================================================
# bokji-ai 환경 변수 템플릿
# 사용법: cp .env.example .env.local 후 각 값을 채워 넣으세요.
# =============================================================================

# -----------------------------------------------------------------------------
# 앱 기본 설정
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# 데이터베이스 (PostgreSQL + pgvector)
# Supabase 사용 시: 프로젝트 Settings > Database > Connection string (URI)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase (TRD 권장: Auth + DB + pgvector)
# https://supabase.com/dashboard > 프로젝트 생성 > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# 인증 (Auth.js / NextAuth)
# AUTH_SECRET 생성: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=your_auth_secret_here
AUTH_URL=http://localhost:3000

# OAuth (선택 — 소셜 로그인 사용 시)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_KAKAO_ID=
# AUTH_KAKAO_SECRET=

# -----------------------------------------------------------------------------
# AI / LLM (Gemini — 상담, 요약, 임베딩)
# https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# -----------------------------------------------------------------------------
# 공공데이터 API (복지 공고 수집 워커 — 백그라운드 전용)
# https://www.data.go.kr > 회원가입 > API별 활용신청 > 인증키 확인
# ⚠️ 복지로(apis.data.go.kr)와 정부24(api.odcloud.kr)는 활용신청·키가 분리됩니다.
# -----------------------------------------------------------------------------

# 복지로 — apis.data.go.kr 인증키
DATA_GO_KR_SERVICE_KEY=your_data_go_kr_service_key

# 복지로 — 중앙부처 복지서비스
# https://www.data.go.kr/data/15090532/openapi.do
# operation: NationalWelfarelistV001 / NationalWelfaredetailedV001
# 공통 필수 파라미터: callTp (L=목록, D=상세), srchKeyCode (목록)
BOKJIRO_CENTRAL_API_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001

# 복지로 — 지자체 복지서비스 (별도 활용신청 필요)
# https://www.data.go.kr/data/15108347/openapi.do
# operation: LcgvWelfarelist (목록) / LcgvWelfaredetailed (상세)  ← V001 아님
# 공통 필수 파라미터: callTp (L=목록, D=상세), srchKeyCode (목록)
# 응답 지역 필드: ctpvNm(시도) / sggNm(시군구)
BOKJIRO_LOCAL_API_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations

# 정부24 — 대한민국 공공서비스(혜택) 정보
# https://www.data.go.kr/data/15113968/openapi.do
# Base: https://api.odcloud.kr/api
# Swagger: https://infuser.odcloud.kr/api/stages/44436/api-docs
# endpoints: /gov24/v3/serviceList | serviceDetail | supportConditions
GOV24_SERVICE_KEY=your_gov24_service_key
GOV24_API_BASE_URL=https://api.odcloud.kr/api

# 사회서비스 전자바우처 — 공통코드 조회 (온톨로지 코드表)
# https://www.data.go.kr/data/15059061/openapi.do
# v1.5 이후 Base: https://api.socialservice.or.kr:444/api/service/common
# endpoints: /sido | /sido/signgu | /serviceType
# ⚠️ data.go.kr 키와 동일할 수 있음. 호출은 api.socialservice.or.kr (포털 UI는 www)
# 안내: https://www.socialservice.or.kr:444/user/pubdata/openapi/openapiList.do
SOCIALSERVICE_API_KEY=your_socialservice_api_key
SOCIALSERVICE_COMMON_API_BASE_URL=https://api.socialservice.or.kr:444/api/service/common

# -----------------------------------------------------------------------------
# SMS 알림 (국내 발송 API — Solapi 예시)
# https://solapi.com > 회원가입 > API Key 발급
# 대안: NCP SENS, Twilio, Aligo
# -----------------------------------------------------------------------------
SMS_PROVIDER=solapi
SOLAPI_API_KEY=your_solapi_api_key
SOLAPI_API_SECRET=your_solapi_api_secret
SMS_SENDER_NUMBER=01012345678

# NCP SENS 사용 시 (SMS_PROVIDER=ncp)
# NCP_ACCESS_KEY=
# NCP_SECRET_KEY=
# NCP_SMS_SERVICE_ID=

# -----------------------------------------------------------------------------
# 이메일 알림
# Resend 권장: https://resend.com/api-keys
# 대안: SendGrid, AWS SES, SMTP
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=bokji-ai <noreply@yourdomain.com>

# SMTP 사용 시 (EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# 스케줄러 / Cron (데이터 수집·알림 워커 보호)
# Vercel Cron 호출 시 Authorization 헤더 검증용
# 생성: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret_here

# Vercel Cron (배포 시)
# CRON_COLLECT_BENEFITS=0 2 * * *
# CRON_SEND_NOTIFICATIONS=0 9 * * *
